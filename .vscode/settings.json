{
  "latex-workshop.latex.outDir": "%DIR%/build",
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "nix-shell",
      "args": [
        "%WORKSPACE_FOLDER%/shell.nix",
        "--run",
        "latexmk -synctex=1 -interaction=nonstopmode -file-line-error -pdf -outdir=%OUTDIR% %DOC%"
      ],
      "env": {}
    },
    {
      "name": "pdflatex",
      "command": "nix-shell",
      "args": [
        "%WORKSPACE_FOLDER%/shell.nix",
        "--run",
        "pdflatex -synctex=1 -interaction=nonstopmode -file-line-error -output-directory=%OUTDIR% %DOC%"
      ],
      "env": {}
    },
    {
      "name": "bibtex",
      "command": "nix-shell",
      "args": [
        "%WORKSPACE_FOLDER%/shell.nix",
        "--run",
        "bibtex %DOCFILE%"
      ],
      "env": {}
    },
    {
      "name": "copy-pdf",
      "command": "cp",
      "args": [
        "%OUTDIR%/%DOCFILE%.pdf",
        "%DIR%/DavidChan_Resume.pdf"
      ],
      "env": {}
    },
    {
      "name": "generate-preview",
      "command": "nix-shell",
      "args": [
        "%WORKSPACE_FOLDER%/shell.nix",
        "--run",
        "pdftoppm -png -r 150 -singlefile %DIR%/DavidChan_Resume.pdf %DIR%/build/preview"
      ],
      "env": {}
    },
    {
      "name": "pdflatex-dark",
      "command": "nix-shell",
      "args": [
        "%WORKSPACE_FOLDER%/shell.nix",
        "--run",
        "pdflatex -synctex=1 -interaction=nonstopmode -file-line-error -output-directory=%OUTDIR% -jobname=%DOCFILE%_Dark '\\def\\darkmodeenabled{1}\\newif\\ifdarkmode\\darkmodetrue\\input{%DOC%}'"
      ],
      "env": {}
    },
    {
      "name": "copy-pdf-dark",
      "command": "cp",
      "args": [
        "%OUTDIR%/%DOCFILE%_Dark.pdf",
        "%DIR%/DavidChan_Resume_Dark.pdf"
      ],
      "env": {}
    },
    {
      "name": "generate-preview-dark",
      "command": "nix-shell",
      "args": [
        "%WORKSPACE_FOLDER%/shell.nix",
        "--run",
        "pdftoppm -png -r 150 -singlefile %DIR%/DavidChan_Resume_Dark.pdf %DIR%/build/preview_dark"
      ],
      "env": {}
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk 🔃",
      "tools": [
        "latexmk",
        "copy-pdf",
        "generate-preview",
        "pdflatex-dark",
        "copy-pdf-dark",
        "generate-preview-dark"
      ]
    },
    {
      "name": "pdflatex ➞ bibtex ➞ pdflatex × 2",
      "tools": [
        "pdflatex",
        "bibtex",
        "pdflatex",
        "pdflatex",
        "copy-pdf",
        "generate-preview"
      ]
    }
  ],
  "latex-workshop.view.pdf.viewer": "tab"
}
